# Paygrid backend — environment template (copy to .env)

# Supabase — Project Settings → API
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# Privy — app settings
PRIVY_APP_ID=
PRIVY_APP_SECRET=
# Optional: paste the JWT verification key from Privy to avoid JWKS fetches at runtime
PRIVY_JWT_VERIFICATION_KEY=

# Supabase — Project Settings → Database → Connection string (for npm run db:migrate)
DATABASE_URL=

# Celo Sepolia
CELO_SEPOLIA_RPC=https://lb.drpc.live/celo-sepolia/YOUR_DRPC_KEY
CHAIN_ID=11142220
PAYGRID_LINK_ADDRESS=0xd2dc71c47803b0939944ec29ff3b644c48bae7de
PAYGRID_ROUTER_ADDRESS=0xe75027ff07931ef97248402f4df63a4d3287020d

# Relayer wallet (same key as AGENT_PRIVATE_KEY in agent/.env)
BACKEND_WALLET_PRIVATE_KEY=

PORT=3001
