# Paygrid backend — environment template (copy to .env)

# Supabase — Project Settings → API
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
CORS_ORIGINS=http://localhost:3002
SUPABASE_ANON_KEY=
PUBLIC_APP_URL=https://celopaygrid.xyz

# Privy — app settings
PRIVY_APP_ID=
PRIVY_APP_SECRET=
# Optional: paste the JWT verification key from Privy to avoid JWKS fetches at runtime
PRIVY_JWT_VERIFICATION_KEY=

# Fonbnk
FONBNK_API_KEY=
FONBNK_API_BASE_URL=https://sandbox-api.fonbnk.com
FONBNK_PAY_BASE_URL=https://sandbox-pay.fonbnk.com
FONBNK_WEBHOOK_SECRET=

# Ramp Network
# demo uses Ramp's Celo Alfajores assets; production supports Celo mainnet USDC/USDT.
RAMP_API_KEY=
RAMP_ENV=demo
RAMP_WEBHOOK_BASE_URL=
RAMP_WEBHOOK_PUBLIC_KEY=

ROUTER_OWNER_PRIVATE_KEY=

# MCP HTTP remote service. Keep empty to disable write tools in hosted MCP.
PAYGRID_MCP_API_KEY=

# Supabase — Project Settings → Database → Connection string (for npm run db:migrate)
DATABASE_URL=

# Celo RPC. Sepolia: CHAIN_ID=11142220. Mainnet: CHAIN_ID=42220.
CELO_RPC_URL=https://lb.drpc.live/celo-sepolia/YOUR_DRPC_KEY
CHAIN_ID=11142220
PAYGRID_LINK_ADDRESS=0x86D9B260F96873e82852B476ff7B0c93bD755597
PAYGRID_ROUTER_ADDRESS=0x6c3363D33eCD912576051316AF0A1c95F77EAD73
PAYGRID_TREASURY_ADDRESS=0xd4683314a013792fe8840e4171dc4692e317617b

# Gift contracts are optional until DeployGifts.s.sol has been broadcast.
PAYGRID_GIFT_VAULT_ADDRESS=
PAYGRID_GIFT_ROUTER_ADDRESS=
# Use a dedicated signer in production. If empty, BACKEND_WALLET_PRIVATE_KEY signs claim vouchers.
GIFT_CLAIM_SIGNER_PRIVATE_KEY=

# Optional gift claim account preparation. Deploy disabled, migrate first, then fund a dedicated USDm-only wallet.
GIFT_GAS_SPONSOR_ENABLED=false
# Dedicated wallet: keep a small CELO balance for its own fees and USDm for stipends.
GIFT_GAS_SPONSOR_PRIVATE_KEY=
GIFT_GAS_SPONSOR_DAILY_LIMIT_USDM=2
GIFT_GAS_SPONSOR_DAILY_CLAIM_LIMIT=100
GIFT_GAS_SPONSOR_MAX_PER_CLAIM_USDM=0.01
GIFT_GAS_SPONSOR_SAFETY_BPS=2500
GIFT_CLAIM_GAS_FALLBACK=250000
CELO_ATTRIBUTION_CODE=celo_7b12194aeec1
# Celo mainnet fee-currency adapters. Leave empty on other networks unless verified there.
USDC_FEE_CURRENCY_ADDRESS=0x2F25deB3848C207fc8E0c34035B3Ba7fC157602B
USDT_FEE_CURRENCY_ADDRESS=0x0e2a3e05bc9a16f5292a6170456a710cb89c6f72

# Treasury Quant Agent. Keep disabled and in paper mode for the first deployment.
TREASURY_QUANT_ENABLED=false
TREASURY_QUANT_MODE=paper
# Nginx injects this secret for the IP-allowlisted TradingView webhook route.
TREASURY_SIGNAL_SECRET=
# Separate operator key for pause, resume and manual close routes.
TREASURY_ADMIN_API_KEY=
# Dedicated execution wallet. Never reuse a contract owner, treasury Safe or backend relayer key.
TREASURY_EXECUTOR_PRIVATE_KEY=
# Optional read-only address for paper-mode balance display.
TREASURY_EXECUTOR_ADDRESS=
TREASURY_DEFAULT_POSITION_USD=9
TREASURY_MAX_PER_TRADE_USD=12
TREASURY_MAX_TOTAL_EXPOSURE_USD=300
TREASURY_MAX_OPEN_POSITIONS_PER_ASSET=15
TREASURY_DAILY_LOSS_LIMIT_USD=10
TREASURY_MAX_SLIPPAGE_BPS=100
TREASURY_MAX_ENTRY_DEVIATION_BPS=500
TREASURY_MAX_PRICE_DIVERGENCE_BPS=200
# Optional per-asset ceilings. Empty values inherit the global limits above.
TREASURY_WETH_MAX_PER_TRADE_USD=
TREASURY_WETH_MAX_TOTAL_EXPOSURE_USD=
TREASURY_WETH_MAX_OPEN_POSITIONS=
TREASURY_WBTC_MAX_PER_TRADE_USD=
TREASURY_WBTC_MAX_TOTAL_EXPOSURE_USD=
TREASURY_WBTC_MAX_OPEN_POSITIONS=
TREASURY_EURM_MAX_PER_TRADE_USD=
TREASURY_EURM_MAX_TOTAL_EXPOSURE_USD=
TREASURY_EURM_MAX_OPEN_POSITIONS=
TREASURY_ORACLE_MAX_AGE_SECONDS=600
TREASURY_POLL_INTERVAL_MS=15000
TREASURY_CELO_ADDRESS=0x471EcE3750Da237f93B8E339c536989b8978a438
# Chainlink CELO/USD on Celo mainnet. Override explicitly on other networks.
TREASURY_CELO_ORACLE_ADDRESS=0x0568fD19986748cEfF3301e55c0eb1E729E0Ab7e
# XAUt0 on Celo mainnet. RedStone XAUt/USDT updates on deviation or heartbeat,
# so it uses a longer freshness window than the CELO feed.
TREASURY_XAUT0_ADDRESS=0xaf37E8B6C9ED7f6318979f56Fc287d76c30847ff
TREASURY_XAUT0_ORACLE_ADDRESS=0x98DC6E90D4c2f212ed9d124aD2aFBa4833268633
TREASURY_XAUT0_ORACLE_MAX_AGE_SECONDS=90000
# New markets are opt-in. Mainnet token and Chainlink oracle defaults are shown here.
TREASURY_WETH_ENABLED=false
TREASURY_WETH_ADDRESS=0xD221812de1BD094f35587EE8E174B07B6167D9Af
TREASURY_WETH_ORACLE_ADDRESS=0x1FcD30A73D67639c1cD89ff5746E7585731c083B
TREASURY_WETH_ORACLE_MAX_AGE_SECONDS=3600
TREASURY_WBTC_ENABLED=false
TREASURY_WBTC_ADDRESS=0x8aC2901Dd8A1F17a1A4768A6bA4C3751e3995B2D
TREASURY_WBTC_ORACLE_ADDRESS=0x128fE88eaa22bFFb868Bb3A584A54C96eE24014b
TREASURY_WBTC_ORACLE_MAX_AGE_SECONDS=3600
TREASURY_EURM_ENABLED=false
TREASURY_EURM_ADDRESS=0xD8763CBa276a3738E6DE85b4b3bF5FDed6D6cA73
TREASURY_EURM_ORACLE_ADDRESS=0x3D207061Dbe8E2473527611BFecB87Ff12b28dDa
TREASURY_EURM_ORACLE_MAX_AGE_SECONDS=90000

# Optional token address overrides. Use these on testnet if faucet assets differ from mainnet addresses.
# Celo mainnet defaults are:
# USDC 0xcebA9300f2b948710d2653dD7B07f33A8B32118C
# USDT 0x48065fbBE25f71C9282ddf5e1cD6D6A887483D5e
# USDm 0x765DE816845861e75A25fCA122bb6898B8B1282a
USDC_ADDRESS=
USDT_ADDRESS=
USDM_ADDRESS=

# Relayer wallet (same key as AGENT_PRIVATE_KEY in agent/.env)
# Swap routing. Uniswap V3 is used for quoted swap payments; Mento can be whitelisted on-chain.
# Celo mainnet Uniswap V3 SwapRouter02 / QuoterV2:
# UNISWAP_ROUTER_ADDRESS=0x5615CDAb10dc425a742d643d949a7F474C01abc4
# UNISWAP_QUOTER_ADDRESS=0x82825d0554fA07f7FC52Ab63c961F330fdEFa8E8
# MENTO_ROUTER_ADDRESS=0x4861840C2EfB2b98312B0aE34d86fD73E8f9B6f6
UNISWAP_ROUTER_ADDRESS=
UNISWAP_QUOTER_ADDRESS=
UNISWAP_POOL_FEE=500
MENTO_ROUTER_ADDRESS=
MAX_SWAP_SLIPPAGE_BPS=100

BACKEND_WALLET_PRIVATE_KEY=

PORT=3001
INDEXER_START_BLOCK=
