# Paygrid MCP HTTP / stdio environment template

# Hosted MCP write auth. Leave empty to expose read-only tools only.
PAYGRID_MCP_API_KEY=
# Required only for MCP pause/resume/manual-close Treasury Quant tools.
TREASURY_ADMIN_API_KEY=

# MCP public endpoint for ERC-8004 metadata.
MCP_PUBLIC_BASE_URL=https://mcp.celopaygrid.xyz
MCP_PUBLIC_API_URL=https://api.celopaygrid.xyz

# Backend API. Docker compose overrides this to http://backend:3001.
BACKEND_URL=https://api.celopaygrid.xyz

# Agent signing, required for local stdio write tools and hosted agent-owned write calls.
AGENT_PRIVATE_KEY=
ERC8004_AGENT_ID=
PAYGRID_AGENT_NAME=Paygrid Agent
AGENT_ADDRESS=

# Optional Self Protocol Agent ID metadata.
# Use pending until the Self App verification flow is completed.
SELF_AGENT_ID=
SELF_AGENT_ADDRESS=
SELF_VERIFICATION_STATUS=pending
SELF_VERIFICATION_URL=

# Celo. Sepolia: 11142220. Mainnet: 42220.
CHAIN_ID=11142220
CELO_RPC_URL=https://forno.celo-sepolia.celo-testnet.org

# Optional token overrides for testnet.
USDC_ADDRESS=
USDT_ADDRESS=
USDM_ADDRESS=
PAYGRID_GIFT_VAULT_ADDRESS=
PAYGRID_GIFT_ROUTER_ADDRESS=

MCP_HTTP_PORT=3002
