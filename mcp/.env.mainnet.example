# Paygrid MCP HTTP mainnet template

PAYGRID_MCP_API_KEY=
MCP_PUBLIC_BASE_URL=https://mcp.celopaygrid.xyz
MCP_PUBLIC_API_URL=https://api.celopaygrid.xyz

# Docker compose overrides this to http://backend:3001 inside the VPS network.
BACKEND_URL=https://api.celopaygrid.xyz

AGENT_PRIVATE_KEY=
ERC8004_AGENT_ID=
PAYGRID_AGENT_NAME=Paygrid Agent
AGENT_ADDRESS=

# Optional Self Protocol Agent ID metadata.
# Use pending until the Self App verification flow is completed.
SELF_AGENT_ID=
SELF_AGENT_ADDRESS=
SELF_VERIFICATION_STATUS=pending
SELF_VERIFICATION_URL=

CHAIN_ID=42220
CELO_RPC_URL=https://forno.celo.org

# Celo mainnet stablecoin defaults. Leave empty unless you intentionally override.
USDC_ADDRESS=
USDT_ADDRESS=
USDM_ADDRESS=

MCP_HTTP_PORT=3002
