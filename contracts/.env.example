# Copy this file to .env (which is in .gitignore) and replace the values.
# Deploy.s.sol reads PRIVATE_KEY and TREASURY_ADDRESS.
# Example (DO NOT COMMIT .env):
# PRIVATE_KEY=0xaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa

PRIVATE_KEY=0xREPLACE_ME_WITH_64_HEX_CHARS
TREASURY_ADDRESS=0xREPLACE_ME_WITH_TREASURY_ADDRESS
