# Copy this file to .env (which is in .gitignore) and replace the PRIVATE_KEY value.
# For DeployHex.s.sol the PRIVATE_KEY should be the hex private key (0x... 64 hex chars).
# Example (DO NOT COMMIT .env):
# PRIVATE_KEY=0xaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa

PRIVATE_KEY=0xREPLACE_ME_WITH_64_HEX_CHARS
